{
  "name": "dota2skins-mod-manager",
  "productName": "Dota2skins mod manager",
  "version": "1.0.3",
  "description": "Desktop mod manager for Dota 2 — browse, install, toggle and preset 1100+ cosmetic mods from the Dota2PornFx catalog",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dist": "electron-builder --win"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/artem-prime42/dota2skins-mod-manager.git"
  },
  "author": "Mykhailo Lynnyk",
  "license": "GPL-3.0",
  "homepage": "https://github.com/artem-prime42/dota2skins-mod-manager",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.thefleece.dota2skinsmodmanager",
    "productName": "Dota2skins mod manager",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dota2skins mod manager",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "artem-prime42",
      "repo": "dota2skins-mod-manager",
      "releaseType": "release"
    }
  }
}
